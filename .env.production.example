# Sao chép file này thành .env trên VPS. Không commit file .env thật.
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
JWT_SECRET=CHANGE_ME_AT_LEAST_64_RANDOM_CHARACTERS
INTERNAL_SECRET=CHANGE_ME_DIFFERENT_64_RANDOM_CHARACTERS

# Domain thật, không có dấu / ở cuối. Có thể dùng http://IP trong lần thử đầu.
WEB_ORIGIN=https://example.com

# Chỉ bind localhost để aaPanel/Nginx public ra Internet.
WEB_BIND=127.0.0.1
WEB_PORT=8080

# Gmail SMTP (dùng App Password 16 ký tự, không dùng mật khẩu Gmail thật).
APP_URL=http://YOUR_SERVER_IP.sslip.io:8080
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASS=YOUR_16_CHARACTER_APP_PASSWORD
MAIL_FROM=NexaPlay <your-account@gmail.com>
